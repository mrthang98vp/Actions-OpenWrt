# Target đúng cho NR3053 (Xiaomi AX3000T)
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_xiaomi_mi_router-ax3000t=y

# Driver WiFi Full cho chip MT7981
CONFIG_PACKAGE_kmod-mt7981-firmware=y
CONFIG_PACKAGE_kmod-mt79x1-common=y
CONFIG_PACKAGE_kmod-mt7981-common=y
CONFIG_PACKAGE_kmod-mt7981-wifi=y
CONFIG_PACKAGE_wpad-mesh-openssl=y

# Giao diện quản lý (Chỉ dùng theme mặc định cực nhẹ)
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-i18n-base-vi=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# Loại bỏ các App nặng (Chỉ giữ lại những thứ cơ bản để quản lý hệ thống)
# Không cài AdGuard, không TurboAcc, không FileBrowser
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-firewall=y

# Tối ưu RAM & Bộ nhớ
CONFIG_PACKAGE_zram-swap=y
CONFIG_TARGET_ROOTFS_PARTSIZE=220
